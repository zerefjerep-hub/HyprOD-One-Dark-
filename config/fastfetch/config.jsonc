        "height": 22,
        "padding": { "bottom": 1 }
    },
    "display": { "separator": " " },
    "modules": [
        { "key": "в•­в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•®", "type": "custom" },
        { "key": "в”‚ пЂ‡ user    в”‚", "type": "title", "format": "{user-name}" },
        { "key": "в”‚ у°‡… hname   в”‚", "type": "title", "format": "{host-name}" },
        { "key": "в”‚ у°…ђ uptime  в”‚", "type": "uptime" },
        { "key": "в”‚ п…ј distro  в”‚", "type": "os" },
        { "key": "в”‚ пЂ“ kernel  в”‚", "type": "kernel" },
        { "key": "в”‚ ої… wm      в”‚", "type": "wm" },
        { "key": "в”‚ оћ• term    в”‚", "type": "terminal" },
        { "key": "в”‚ п’‰ shell   в”‚", "type": "shell" },
        { "key": "в”‚ у°Ќ› cpu     в”‚", "type": "cpu", "showPeCoreCount": true },
        { "key": "в”‚ у°‰‰ disk    в”‚", "type": "disk", "folders": "/" },
        { "key": "в”‚ ої… memory  в”‚", "type": "memory" },
        { "key": "в”њв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¤", "type": "custom" },
        { "key": "в”‚ PC        в”‚", "type": "host", "format": "{5} {1} ({2})" },
        { "key": "в”‚ в”њ у°ў® gpu   в”‚", "type": "gpu", "format": "{1} {2} @ {12}" },
        { "key": "в”‚ в”њ у°“Ў swap  в”‚", "type": "swap" },
        { "key": "в”‚ в”њ п„€ disp  в”‚", "type": "monitor", "format": "{1} px @ {2} Hz - {3} mm ({4} inches, {5} pp)" },
        { "key": "в”‚ в”” пѓ§ dtime в”‚", "type": "command", "text": "birth_install=$(stat -c %W /); current=$(date +%s); time_progression=$((current - birth_install)); days_difference=$((time_progression / 86400)); echo $days_difference days" },
        { "key": "в”‚ оїЊ colors  в”‚", "type": "colors", "symbol": "circle" },
